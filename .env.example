# URL publique du site (utilisée pour les métadonnées OG et le sitemap)
NEXT_PUBLIC_BASE_URL=https://liyen.fr

# Clé API Resend pour l'envoi des emails de contact
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email de destination pour les formulaires de contact
CONTACT_EMAIL=contact@liyen.fr

# Umami Analytics (laisser vides pour désactiver en local)
# NEXT_PUBLIC_UMAMI_URL=https://analytics.liyen.fr
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Umami — base de données (pour docker-compose.infra.yml)
# UMAMI_DB_PASSWORD=un_mot_de_passe_fort
# UMAMI_APP_SECRET=une_chaine_aleatoire_longue

# Développement local uniquement
# En production, ces variables sont injectées par le serveur/Portainer
